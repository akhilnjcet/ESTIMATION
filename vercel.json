{
  "version": 2,
  "functions": {
    "backend/server.js": {
      "runtime": "@vercel/node",
      "includeFiles": "uploads/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/uploads/(.*)", "destination": "/api/uploads/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
